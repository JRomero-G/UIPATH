# .env.example
# Copia este archivo a .env y rellena los valores reales
# Nunca subas el .env real al control de versiones (debe estar en .gitignore)

# === BASE DE DATOS (MySQL) ===
# Formato recomendado: mysql+aiomysql://usuario:contraseña@host:puerto/nombre_db?opciones
DATABASE_URL=mysql+aiomysql://root:tu_contraseña_segura@localhost:3306/portal_db?charset=utf8mb4&use_unicode=1

# Opcional: si prefieres variables separadas (algunos prefieren por claridad)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=portal_db
# DB_USER=root
# DB_PASSWORD=tu_contraseña_segura

# === ENTORNO Y DEBUG ===
ENV=development          # development | production | testing
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR | CRITICAL
FASTAPI_RELOAD=true      # true solo en desarrollo (uvicorn --reload)

# === API y Seguridad ===
API_KEY=tu_clave_secreta_para_ui_o_tests   # Para autenticación simple (X-API-Key)
# SECRET_KEY=tu_clave_larga_y_segura_para_jwt_o_sessiones (si lo implementas después)

# === PUERTOS (para desarrollo local) ===
BACKEND_PORT=8000
FRONTEND_PORT=8501       # Streamlit por defecto

# === OTROS (opcionales según tu proyecto) ===
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=tu_correo@gmail.com
# EMAIL_PASSWORD=tu_app_password
# DEFAULT_FROM_EMAIL=notificaciones@tu-dominio.com

# === RUTAS DE ARCHIVOS ===
DATA_INPUT_DIR=./data/input
DATA_OUTPUT_DIR=./data/output
DATA_TEMP_DIR=./data/temp

# === Si usas algún servicio externo en el futuro ===
# SCRAPING_API_KEY=xxx
# STORAGE_BUCKET_NAME=tu-bucket-s3